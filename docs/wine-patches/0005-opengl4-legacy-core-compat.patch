+
+        add_sampler_binding( &bindings, name_start, name_length, parsed_binding, 1, TRUE );
+        for (clear = layout; clear <= layout_end; ++clear)
+            if (*clear != '\n') *clear = ' ';
+        if (replacement && replacement_length <= (size_t)(layout_end + 1 - layout))
+            memcpy( layout, replacement, replacement_length );
+        layout = layout_end + 1;
+    }
+    return bindings;
+}
+
+void wrap_glShaderSource_legacy_bindings( const struct opengl_funcs *funcs, GLuint shader,
+                                          GLsizei count, const GLchar *const *strings,
+                                          const GLint *lengths )
+{
+    struct glsl_sampler_binding *bindings, *uniform_blocks, *tail;
+    const GLchar *rewritten_string;
+    GLint rewritten_length;
+    char *rewritten;
+
+    if (!force_core_context_enabled() ||
+        !(rewritten = join_shader_source( count, strings, lengths, &rewritten_length )))
+    {
+        funcs->p_glShaderSource( shader, count, strings, lengths );
+        return;
+    }
+
+    neutralize_core_extension_directives( rewritten );
+    bindings = rewrite_sampler_bindings( rewritten );
+    uniform_blocks = rewrite_uniform_block_bindings( rewritten );
+    if (bindings)
+    {
+        for (tail = bindings; tail->next; tail = tail->next) {}
+        tail->next = uniform_blocks;
+    }
+    else bindings = uniform_blocks;
+    rewritten_string = rewritten;
+    funcs->p_glShaderSource( shader, 1, &rewritten_string, &rewritten_length );
+    remember_shader_bindings( shader, bindings );
+    free( rewritten );
+}
+
+static void merge_sampler_binding( struct glsl_sampler_binding **bindings,
+                                   const struct glsl_sampler_binding *candidate )
+{
+    struct glsl_sampler_binding *entry;
+
+    for (entry = *bindings; entry; entry = entry->next)
+    {
+        if (entry->uniform_block != candidate->uniform_block ||
+            strcmp( entry->name, candidate->name )) continue;
+        if (entry->binding != candidate->binding || entry->count != candidate->count)
+            WARN( "Conflicting opt-in GLSL binding for %s; keeping %d\n",
+                  entry->name, entry->binding );
+        return;
+    }
+
+    if (!(entry = copy_sampler_binding( candidate->name, strlen( candidate->name ),
+                                        candidate->binding, candidate->count,
+                                        candidate->uniform_block ))) return;
+    entry->next = *bindings;
+    *bindings = entry;
+}
+
+void apply_glsl_legacy_sampler_bindings( const struct opengl_funcs *funcs, GLuint program )
+{
+    struct glsl_sampler_binding *bindings = NULL, *binding;
+    struct glsl_shader_bindings *record;
+    GLsizei shader_count = 0, attached_count = 0, i;
+    GLint link_status = GL_FALSE;
+    GLuint *shaders;
+
+    if (!force_core_context_enabled() || !funcs->p_glGetProgramiv ||
+        !funcs->p_glGetAttachedShaders) return;
+
+    funcs->p_glGetProgramiv( program, GL_LINK_STATUS, &link_status );
+    if (!link_status) return;
+    funcs->p_glGetProgramiv( program, GL_ATTACHED_SHADERS, &shader_count );
+    if (shader_count <= 0 || !(shaders = calloc( shader_count, sizeof(*shaders) ))) return;
+    funcs->p_glGetAttachedShaders( program, shader_count, &attached_count, shaders );
+
+    pthread_mutex_lock( &wgl_lock );
+    for (i = 0; i < attached_count; ++i)
+    {
+        for (record = glsl_shader_bindings; record; record = record->next)
+        {
+            if (record->shader != shaders[i]) continue;
+            for (binding = record->bindings; binding; binding = binding->next)
+                merge_sampler_binding( &bindings, binding );
+            break;
+        }
+    }
+    pthread_mutex_unlock( &wgl_lock );
+    free( shaders );
+
+    for (binding = bindings; binding; binding = binding->next)
+    {
+        GLint location;
+        GLint *values;
+
+        if (binding->uniform_block)
+        {
+            GLuint index;
+
+            if (!funcs->p_glGetUniformBlockIndex || !funcs->p_glUniformBlockBinding) continue;
+            index = funcs->p_glGetUniformBlockIndex( program, binding->name );
+            if (index == GL_INVALID_INDEX) continue;
+            funcs->p_glUniformBlockBinding( program, index, binding->binding );
+            TRACE( "Applied opt-in GLSL uniform block binding %s=%d to program %u\n",
+                   binding->name, binding->binding, program );
+            continue;
+        }
+
+        if (!funcs->p_glGetUniformLocation) continue;
+        location = funcs->p_glGetUniformLocation( program, binding->name );
+
+        if (location < 0) continue;
+        if (!(values = malloc( binding->count * sizeof(*values) ))) continue;
+        for (i = 0; i < binding->count; ++i) values[i] = binding->binding + i;
+
+        if (funcs->p_glProgramUniform1iv)
+            funcs->p_glProgramUniform1iv( program, location, binding->count, values );
+        else if (funcs->p_glGetIntegerv && funcs->p_glUseProgram && funcs->p_glUniform1iv)
+        {
+            GLint current_program;
+            funcs->p_glGetIntegerv( GL_CURRENT_PROGRAM, &current_program );
+            funcs->p_glUseProgram( program );
+            funcs->p_glUniform1iv( location, binding->count, values );
+            funcs->p_glUseProgram( current_program );
+        }
+        TRACE( "Applied opt-in GLSL sampler binding %s=%d (%d element(s)) to program %u\n",
+               binding->name, binding->binding, binding->count, program );
+        free( values );
+    }
+    free_sampler_bindings( bindings );
+}
