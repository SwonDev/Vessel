+        if (*cursor++ != '(') { layout += 6; continue; }
+        cursor = skip_glsl_space( cursor );
+        if (!glsl_keyword( cursor, "binding", &cursor )) { layout += 6; continue; }
+        cursor = skip_glsl_space( cursor );
+        if (*cursor++ != '=') { layout += 6; continue; }
+        cursor = skip_glsl_space( cursor );
+        parsed_binding = strtoul( cursor, &number_end, 10 );
