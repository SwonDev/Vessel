+static void bind_legacy_default_vertex_array( struct context *ctx,
+                                              const struct opengl_funcs *funcs )
+{
+    if (!force_core_context_enabled() || !funcs->p_glGenVertexArrays ||
+        !funcs->p_glBindVertexArray)
+        return;
+
+    if (!ctx->legacy_default_vao)
+        funcs->p_glGenVertexArrays( 1, &ctx->legacy_default_vao );
+    if (!ctx->legacy_vao_binding)
+        funcs->p_glBindVertexArray( ctx->legacy_default_vao );
+}
+
+void wrap_glBindVertexArray_legacy_default( TEB *teb, const struct opengl_funcs *funcs,
+                                           GLuint array )
+{
+    struct context *ctx = get_current_context( teb, NULL, NULL );
+
+    if (!ctx || !force_core_context_enabled() || !ctx->legacy_default_vao)
+    {
+        funcs->p_glBindVertexArray( array );
+        return;
+    }
+
+    ctx->legacy_vao_binding = array;
+    funcs->p_glBindVertexArray( array ? array : ctx->legacy_default_vao );
 }
 
