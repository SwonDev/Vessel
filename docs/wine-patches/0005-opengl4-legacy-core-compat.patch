+void wrap_glDrawElements_legacy_quads( const struct opengl_funcs *funcs, GLenum mode,
+                                      GLsizei count, GLenum type, const void *indices )
+{
+    SIZE_T element_size, offset;
+    GLsizei first;
+
+    if (!force_core_context_enabled() || mode != GL_QUADS || count < 0)
+    {
+        funcs->p_glDrawElements( mode, count, type, indices );
+        return;
+    }
+
+    switch (type)
+    {
+        case GL_UNSIGNED_BYTE:
+            element_size = sizeof(GLubyte);
+            break;
+        case GL_UNSIGNED_SHORT:
+            element_size = sizeof(GLushort);
+            break;
+        case GL_UNSIGNED_INT:
+            element_size = sizeof(GLuint);
+            break;
+        default:
+            funcs->p_glDrawElements( mode, count, type, indices );
+            return;
+    }
+
+    for (first = 0; first + 3 < count; first += 4)
+    {
+        offset = (SIZE_T)first * element_size;
+        funcs->p_glDrawElements( GL_TRIANGLE_FAN, 4, type,
+                                 (const void *)((UINT_PTR)indices + offset) );
+    }
