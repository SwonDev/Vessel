+    if (!(entry = calloc( 1, sizeof(*entry) ))) return NULL;
+    if (!(entry->name = malloc( name_length + 1 )))
+    {
+        free( entry );
+        return NULL;
+    }
+
+    memcpy( entry->name, name, name_length );
+    entry->name[name_length] = 0;
+    entry->binding = binding;
+    entry->count = count;
+    entry->uniform_block = uniform_block;
+    return entry;
