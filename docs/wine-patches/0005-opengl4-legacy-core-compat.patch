+/* Build the legacy space-separated extension string from the extension array
+ * already discovered with glGetStringi().  Core profiles intentionally reject
+ * glGetString(GL_EXTENSIONS), but some older Windows loaders still depend on
+ * that form even when they otherwise support modern OpenGL. */
+static GLubyte *build_legacy_extension_string( struct context *ctx )
+{
+    static const char promoted_extensions[] =
+        "GL_ARB_draw_instanced GL_ARB_framebuffer_object GL_ARB_uniform_buffer_object "
+        "GL_ARB_map_buffer_range GL_ARB_vertex_array_object ";
+    struct opengl_client_context *client = opengl_client_context_from_client( ctx->base.client_context );
+    enum opengl_extension ext;
+    size_t i, size = sizeof(promoted_extensions);
+    char *ret, *p;
+
+    for (i = 0; i < client->extension_count; i++)
+    {
+        ext = client->extension_array[i];
+        if (ext >= WGL_FIRST_EXTENSION) continue;
+        size += all_extensions[ext].len + 1;
+    }
+
+    if (!(p = ret = malloc( size ))) return NULL;
+
+    for (i = 0; i < client->extension_count; i++)
+    {
+        ext = client->extension_array[i];
+        if (ext >= WGL_FIRST_EXTENSION) continue;
+        memcpy( p, all_extensions[ext].name, all_extensions[ext].len );
+        p += all_extensions[ext].len;
+        *p++ = ' ';
+    }
+    memcpy( p, promoted_extensions, sizeof(promoted_extensions) - 1 );
+    p += sizeof(promoted_extensions) - 1;
+    *p = 0;
+    return (GLubyte *)ret;
+}
