 #endif
 
+#if MVK_MACOS && !MVK_MACCAT
+@interface MVKLayerFocusPresentationObserver : NSObject {
+    CAMetalLayer* _layer;
+}
+-(instancetype) initWithLayer: (CAMetalLayer*) layer;
+@end
+
+@implementation MVKLayerFocusPresentationObserver
+
+-(instancetype) initWithLayer: (CAMetalLayer*) layer {
+    self = [super init];
+    if (self) {
+        _layer = layer;
+        NSNotificationCenter* center = NSNotificationCenter.defaultCenter;
+        [center addObserver: self selector: @selector(applicationDidBecomeActive:)
+                       name: NSApplicationDidBecomeActiveNotification object: nil];
+        [center addObserver: self selector: @selector(windowDidBecomeKey:)
+                       name: NSWindowDidBecomeKeyNotification object: nil];
+    }
+    return self;
+}
+
+-(void) dealloc {
+    [NSNotificationCenter.defaultCenter removeObserver: self];
+    [super dealloc];
+}
+
+-(NSView*) layerView {
+    id delegate = _layer.delegate;
+    return [delegate isKindOfClass: NSView.class] ? (NSView*)delegate : nil;
+}
+
+-(void) refreshPresentation {
+    NSView* view = self.layerView;
+    if (!view || !view.window || !view.window.visible) { return; }
+    [CATransaction begin];
+    [CATransaction setDisableActions: YES];
+    [_layer setNeedsDisplay];
+    [view setNeedsDisplay: YES];
+    [CATransaction commit];
+    [CATransaction flush];
+}
+
+-(void) applicationDidBecomeActive: (NSNotification*) notification {
+    [self refreshPresentation];
+}
+
+-(void) windowDidBecomeKey: (NSNotification*) notification {
+    NSView* view = self.layerView;
+    if (view.window == notification.object) { [self refreshPresentation]; }
+}
+
+@end
+
+static void* kMVKLayerFocusPresentationObserverKey = &kMVKLayerFocusPresentationObserverKey;
+#endif
 
 @implementation CAMetalLayer (MoltenVK)
 
