+#if defined(MVK_IDTECH_FLOAT64_COMPAT) && MVK_IDTECH_FLOAT64_COMPAT
+// Metal no expone tipos de coma flotante de 64 bits. Algunos renderers id Tech conservan
+// conversiones temporales a double en shaders auxiliares (por ejemplo, para formatear cifras),
+// aunque el resultado vuelva inmediatamente a float. El runtime de compatibilidad aislado puede
+// reducir solo esos tokens de tipo a float sin alterar nombres de funciones como doubleBitsTo*.
+static void reduceUnsupportedMSLDoubleTypes(string& source) {
+	const string token = "double";
+	size_t position = 0;
+	while ((position = source.find(token, position)) != string::npos) {
+		const bool leftBoundary = position == 0 ||
+			(!isalnum(static_cast<unsigned char>(source[position - 1])) && source[position - 1] != '_');
+		const size_t suffix = position + token.size();
+		size_t typeEnd = suffix;
+		if (typeEnd < source.size() && source[typeEnd] >= '2' && source[typeEnd] <= '4') {
+			typeEnd++;
+		}
+		const bool rightBoundary = typeEnd == source.size() ||
+			(!isalnum(static_cast<unsigned char>(source[typeEnd])) && source[typeEnd] != '_');
+		if (leftBoundary && rightBoundary) {
+			source.replace(position, token.size(), "float");
+			position += 5;
+		} else {
+			position = suffix;
+		}
+	}
+}
+#endif
