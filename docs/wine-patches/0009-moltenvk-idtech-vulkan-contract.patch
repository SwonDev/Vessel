+-(void) installFocusPresentationRefreshMVK {
+#if MVK_MACOS && !MVK_MACCAT
+    NSString* enabled = NSProcessInfo.processInfo.environment[@"MVK_CONFIG_REFRESH_METAL_LAYER_ON_FOCUS"];
+    if (!enabled.boolValue || objc_getAssociatedObject(self, kMVKLayerFocusPresentationObserverKey)) {
+        return;
+    }
+    MVKLayerFocusPresentationObserver* observer =
+        [[MVKLayerFocusPresentationObserver alloc] initWithLayer: self];
+    objc_setAssociatedObject(self,
+                             kMVKLayerFocusPresentationObserverKey,
+                             observer,
+                             OBJC_ASSOCIATION_RETAIN_NONATOMIC);
+    [observer release];
+#endif
+}
