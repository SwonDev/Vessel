--- /dev/fd/11	2026-07-17 09:42:37
+++ wine-clean/wine-11.10/dlls/ddraw/ddraw.c	2026-07-17 09:42:37
@@ -1087,6 +1087,7 @@
 static HRESULT WINAPI ddraw7_SetDisplayMode(IDirectDraw7 *iface, DWORD width, DWORD height,
         DWORD bpp, DWORD refresh_rate, DWORD flags)
 {
+    BOOL mode_changed = TRUE;
     struct ddraw *ddraw = impl_from_IDirectDraw7(iface);
     struct wined3d_display_mode mode;
     enum wined3d_format_id format;
@@ -1136,6 +1137,15 @@
 
     /* TODO: The possible return values from msdn suggest that the screen mode
      * can't be changed if a surface is locked or some drawing is in progress. */
+    /* Averiguamos si el modo cambia DE VERDAD, antes de aplicarlo (ver la nota del final). */
+    {
+        struct wined3d_display_mode cur;
+
+        if (SUCCEEDED(wined3d_output_get_display_mode(ddraw->wined3d_output, &cur, NULL)))
+            mode_changed = cur.width != mode.width || cur.height != mode.height
+                    || cur.format_id != mode.format_id;
+    }
+
     if (SUCCEEDED(hr = wined3d_output_set_display_mode(ddraw->wined3d_output, &mode)))
     {
         if (ddraw->primary)
@@ -1157,7 +1167,15 @@
         }
     }
 
-    InterlockedCompareExchange(&ddraw->device_state, DDRAW_DEVICE_STATE_NOT_RESTORED, DDRAW_DEVICE_STATE_OK);
+    /* Una aplicacion en modo EXCLUSIVO es duena de la pantalla: cambiar SU PROPIO modo no debe
+     * costarle sus superficies. Antes se marcaba NOT_RESTORED en CUALQUIER SetDisplayMode, y el
+     * siguiente CreateSurface disparaba ddraw_update_lost_surfaces(), que marcaba como perdidas
+     * la primaria y el backbuffer YA CREADOS. Las aplicaciones que no llaman a Restore() se
+     * quedan con TODOS los Flip devolviendo DDERR_SURFACELOST -> pantalla negra para siempre.
+     * Caso real: War Wind (1996) crea sus superficies a 640x480 y despues cambia a 320x240 para
+     * su intro. Fuera de modo exclusivo se conserva el comportamiento anterior. */
+    if (mode_changed && !(ddraw->cooperative_level & DDSCL_EXCLUSIVE))
+        InterlockedCompareExchange(&ddraw->device_state, DDRAW_DEVICE_STATE_NOT_RESTORED, DDRAW_DEVICE_STATE_OK);
 
     wined3d_mutex_unlock();
 
